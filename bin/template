 */

{{classes}}

define('JIRA_CLIENT_VERSION', '{{version}}');

// Bootstrap

$output = new Output();
$app = new App(new CommandParser($argv), $output);

try {
    $app->run();
} catch (CommandException $e) {
    $output->error($e->getMessage());
    exit(1);
} catch (RuntimeException $e) {
    $output->error($e->getMessage());
    exit(1);
}
